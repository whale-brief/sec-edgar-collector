# ==========================================
# Database Configuration
# ==========================================
# Connection string for NeonDB (Serverless PostgreSQL) - Required
DATABASE_URL="postgresql://[user]:[password]@[host].neon.tech/whale-brief-db?sslmode=require"

# ==========================================
# SEC EDGAR API Configuration
# ==========================================
# User-Agent string required by SEC guidelines (Include Name/Company and Email)
SEC_USER_AGENT="YourName team@yourdomain.com"

# ==========================================
# NVIDIA NIM AI Multi-Agent Configuration
# ==========================================
# API Key for NVIDIA NIM Endpoint - Required
NVIDIA_API_KEY="nvapi-..."

# [The Brain] Reasoning Engine: 400B MoE model for cross-domain anomaly detection
AI_REASONING_MODEL="qwen3.5-397b-a17b"

# [The Scribe KO] Localization Engine: DeepSeek V4 Flash optimized for aggressive Korean retail community tone
AI_REPORT_MODEL_KO="deepseek-v4-flash"

# [The Scribe JA] Localization Engine: Qwen 122B MoE optimized for formal Japanese analyst report tone
AI_REPORT_MODEL_JA="qwen3.5-122b-a10b"